  "goals": [
    {
      "local_id": "mo375j9atnh9",
      "title": "Improve my strength & cardiovascular health",
      "area": "health",
      "why": "If my son ever wants to do sports, I don't want to be the old Dad who couldn't run with him or play with him like he wants.",
      "status": "active"
    },
    {
      "local_id": "mo6t939hu1n6",
      "title": "I will take my family on a vacation this year.",
      "area": "family",
      "why": "I believe a lot of inspiration comes from seeing new things.  I want that for my family.",
      "status": "paused"
    },
    {
      "local_id": "mocfgbl45xj0",
      "title": "I will fix my anterior pelvic tilt and walk with good posture.",
      "area": "health",
      "why": "When I look at myself in the mirror, I see my belly and my butt poking out... I'm not pleased with that.  Yes, a lot of that is fat.  I'm working on that too.  but, I noticed, when I forcefully correct my posture by squeezing my abs and my butt... I look much better.  I don't want to have Auntie booty anymore!",
      "status": "active"
    },
    {
      "local_id": "mocim2hmxtip",
      "title": "I will create a habit of keeping my room clean and organized",
      "area": "personal",
      "why": "In Zen Buddhism, they say the state of your room is a reflection of the state of your mind.  If that is the case... my mind is an absolute mess!  I need to fix that.",
      "status": "active"
    }
  ],
