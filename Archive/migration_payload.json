  "visions": [
    {
      "area": "health",
      "content": "I want to be the strongest, fastest, most physically Dad my son could ever want."
    },
    {
      "area": "family",
      "content": "I want my family to regularly travel the world and see places and people the would normally only see on TV."
    },
    {
      "area": "work",
      "content": "I want to be so financially successful that it would show my family that the time, effort, and money they put into supporting me was not in vain."
    }
