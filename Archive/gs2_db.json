\f0\fs24 \cf0 \{"visions":\{"health":"I want to be the strongest, fastest, most physically Dad my son could ever want.","family":"I want my family to regularly travel the world and see places and people the would normally only see on TV.","career":"I want to be so financially successful that it would show my family that the time, effort, and money they put into supporting me was not in vain."\},"goals":[\{"id":"mo375j9atnh9","title":"Improve my strength & cardiovascular health","areaId":"health","why":"If my son ever wants to do sports, I don't want to be the old Dad who couldn't run with him or play with him like he wants.","status":"active","indicators":[\{"id":"mo36v20dj7gw","text":"60,000 Steps","freq":"Weekly"\},\{"id":"mo377ylpyp9c","text":"10,000 Steps","freq":"Daily"\}],"metrics":[\{"id":"mo36v20ew0jd","type":"Duration","name":"100m Sprint","target":"15 Sec."\},\{"id":"mo6r74xf4oa0","type":"Number","name":"Strict Form Pullups","target":"12 reps"\},\{"id":"mo6r7koftq1v","type":"Number","name":"Strict Form Pushups","target":"50 reps"\}],"metricLogs":\{"mo6r7koftq1v":[\{"date":"2026-04-26","value":30,"note":"I tested this just before bed.  Not sure if that effected my results."\}],"mo6r74xf4oa0":[\{"date":"2026-04-27","value":5,"note":"I didn't sleep well yesterday.  I believe I could have done more."\}]\}\},\{"id":"mo6t939hu1n6","title":"I will take my family on a vacation this year.","areaId":"family","why":"I believe a lot of inspiration comes from seeing new things.  I want that for my family.","status":"paused","metrics":[\{"id":"mo6t89wk7f3l","type":"Currency","name":"Da Nang Travel Money","target":"3,000,000 KRW"\}]\},\{"id":"mocfgbl45xj0","title":"I will fix my anterior pelvic tilt and walk with good posture.","areaId":"health","why":"When I look at myself in the mirror, I see my belly and my butt poking out... I'm not pleased with that.  Yes, a lot of that is fat.  I'm working on that too.  but, I noticed, when I forcefully correct my posture by squeezing my abs and my butt... I look much better.  I don't want to have Auntie booty anymore!","status":"active","metrics":[\{"id":"mocff7cuqg8y","type":"Percentage","name":"Posture Correction","target":"100%"\}]\},\{"id":"mocim2hmxtip","title":"I will create a habit of keeping my room clean and organized","areaId":"personal","why":"In Zen Buddhism, they say the state of your room is a reflection of the state of your mind.  If that is the case... my mind is an absolute mess!  I need to fix that.","status":"active","metrics":[\{"id":"mocimd5rbsyn","type":"Frequency","name":"Maintain an orderly room","target":"Weekly"\}]\}],"sprints":[\{"id":"mo37gaa0x8e2","goalId":"mo375j9atnh9","name":"Q2 The Baseline","outcome":"Hit 85% Execution Each Week","startDate":"2026-04-20","endDate":"2026-07-12","phases":[\{"name":"Foundation","desc":"Creating the habit of moving","tactics":[\{"id":"mo5sxprd6lai","text":"Complete at least 3 morning walks per week","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mo5syf5g5gdt","text":"10,000 Steps per workday","freq":"weekdays","days":[0,1,2,3,4]\},\{"id":"mo5x6gfweovh","text":"60,000 Steps per week"\},\{"id":"mo5yelwmacuj","text":"100 pushups per workout day","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mo5yizpcxvjy","text":"30 pull ups per workout day","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mo5zzhls7b8c","text":"20 second power walks x 4 on morning walk days","freq":"xperweek","days":[],"timesPerWeek":3\}]\},\{"name":"Build","desc":"Ramping up my cardio","tactics":[\{"id":"mo5sywv3m9oe","text":"Complete at least 3 morning walks per week","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mo5x709v5438","text":"60,000 Steps per week"\},\{"id":"mo5x709v90r4","text":"10,000 Steps per workday","freq":"weekdays","days":[0,1,2,3,4]\},\{"id":"mo5zw2mkyyvl","text":"125 pushups per workout day (5x25)","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mo5zx7nfx4gx","text":"40 pull ups on workout days (5 x 8)","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mo5zyd1nfm2j","text":"20 second runs (60%) 90 second breaks (x 3) on morning walk days","freq":"xperweek","days":[],"timesPerWeek":3\}]\},\{"name":"Peak","desc":"Bring it on home!","tactics":[\{"id":"mo601upo4yl4","text":"Complete at least 3 morning walks per week","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mo6022ax5mnt","text":"60,000 Steps per week"\},\{"id":"mo602659govp","text":"10,000 Steps per workday","freq":"weekdays","days":[0,1,2,3,4]\},\{"id":"mo6029cfxcu1","text":"150 pushups per workout day (5x30)","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mo60bsbknx1w","text":"50 pull ups on workout days (10 x 5)","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mo60ceznyies","text":"20 second runs all out 90 second breaks (x 3) on morning walk days","freq":"xperweek","days":[],"timesPerWeek":3\}]\}],"tactics":[\{"id":"mo37bld4bp0c","text":"60,000 Steps per Week"\}],"weekChecks":\{"1":\{"mo5x6gfweovh":true,"mo5sxprd6lai":true,"mo5syf5g5gdt":true,"mo5sxprd6lai_2":true,"mo5sxprd6lai_3":true,"mo5sxprd6lai_4":true,"mo5syf5g5gdt_4":true,"mo5syf5g5gdt_2":true,"mo5syf5g5gdt_1":true,"mo5syf5g5gdt_0":true,"mo5yelwmacuj_4":true,"mo5yelwmacuj_2":true,"mo5yelwmacuj_0":true,"mo5yizpcxvjy_4":true,"mo5yizpcxvjy_2":true,"mo5yizpcxvjy_0":true,"mo5zzhls7b8c_4":true\},"2":\{"mo5syf5g5gdt_0":false,"mo5yelwmacuj_0":true,"mo5yizpcxvjy_0":true,"mo5sxprd6lai_2":false,"mo5syf5g5gdt_1":false,"mo5yelwmacuj_2":false,"mo5yizpcxvjy_2":false,"mo5syf5g5gdt_2":false,"mo5sxprd6lai_3":false,"mo5sxprd6lai_4":false,"mo5zzhls7b8c_4":false,"mo5syf5g5gdt_3":false,"mo5syf5g5gdt_4":false,"mo5yelwmacuj_4":false,"mo5yizpcxvjy_4":false,"mo5x6gfweovh":false\}\},"reflections":\{"1":\{"well":"I completed all of my walking tasks this commitments.  I'm very proud of myself.  Now, I've started other fitness based commitments for my cardio in Week 2","obstacles":"Occasionally, I wasn't always in a place where walking was easy during workdays, but I managed.","next":"Let's complete everything 100%"\}\}\},\{"id":"mocg3ngfrxlw","weekChecks":\{\},"reflections":\{\},"goalId":"mocfgbl45xj0","name":"Q2 Posture Fix","outcome":"I will have reversed my anterior pelvic tilt and walk with an upright posture.","startDate":"2026-04-27","endDate":"2026-07-19","phases":[\{"name":"Foundation","desc":"Focus: Mobilizing the front, waking up the back.\\nWalking Cue: During your walks, focus on \\"tucking your tail\\" slightly and engaging your core as if someone were about to poke your stomach.","tactics":[\{"id":"mocg0l7pjtml","text":"Daily Desk Habit: Set a timer for every 60 minutes. Stand up and perform a 30-second standing hip flexor stretch","freq":"weekdays","days":[0,1,2,3,4]\},\{"id":"mocg278skxoj","text":"Cat-Cow (10 reps): Focus specifically on the \\"tucking\\" motion of the tailbone.","freq":"daily","days":[]\},\{"id":"mocg2nt2hgmm","text":"Deadbugs (3 sets of 10): Focus on keeping your lower back pressed flat against the floor.","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mocg36t0dskk","text":"Glute Bridges (3 sets of 15): Squeeze your glutes hard at the top without arching your back.","freq":"xperweek","days":[],"timesPerWeek":3\}]\},\{"name":"Build","desc":"Focus: Increasing resistance and core control.\\nWalking Cue: Walk at a slightly faster pace. Focus on \\"driving\\" from your glutes rather than pulling with your hip flexors.","tactics":[\{"id":"mocg44qv3fiz","text":"Daily Desk Habit: Introduce \\"Glute Squeezes\\" while sitting. Every hour, squeeze your glutes for 10 seconds to combat \\"gluteal amnesia.\\"","freq":"weekdays","days":[0,1,2,3,4]\},\{"id":"mocg4hy1lgep","text":"Planks (3 sets, max hold): Maintain a \\"Posterior Pelvic Tilt\\" (hollow body) throughout the hold. Do not let your back sag.","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mocg5c3qx66n","text":"Bulgarian Split Squats: Excellent for stretching the hip flexor of the back leg while strengthening the front leg.","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mocg5ovv8w49","text":"Bird-Dogs (3 sets of 12): Focus on stability. Do not let your hips rotate or your back arch as your limbs extend.","freq":"xperweek","days":[],"timesPerWeek":3\}]\},\{"name":"Integration","desc":"Focus: Making neutral posture your \\"new normal.\\"\\nWalking Cue: Practice \\"Active Glute Engagement.\\" On every stride, feel the glute of the trailing leg push you forward.","tactics":[\{"id":"mocg8ogluwow","text":"Romanian Deadlifts: Focus on the \\"hinge\\" and the stretch in the hamstrings, which are often lengthened and weak in APT.","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mocg9881oipx","text":"Weighted Glute Bridges or Hip Thrusts: Increase the load to solidify glute strength.","freq":"xperweek","days":[],"timesPerWeek":3\},\{"id":"mocg9yzs7cn1","text":"Pallof Press: A \\"standing core\\" exercise that teaches you to resist rotation and maintain a neutral spine.","freq":"xperweek","days":[],"timesPerWeek":3\}]\}]\},\{"id":"mocitwnb8f4u","weekChecks":\{"1":\{"mocintghcbvc":true,"mocirvxc9ne3":true\}\},"reflections":\{\},"goalId":"mocim2hmxtip","name":"Q2 Clean Slate Habit","outcome":"By week 12, I will have created a habit of keeping my room clean and organized.","startDate":"2026-04-26","endDate":"2026-07-18","phases":[\{"name":"Foundation","desc":"Maintain a 100% \\"Ready State\\" bedroom for 12 consecutive weeks.","tactics":[\{"id":"mocintghcbvc","text":"Spend time on Saturday/Sunday doing the \\"Big Clean\\" to get to your baseline.","freq":"onetime","days":[]\},\{"id":"mocio5kpgrsz","text":"Before getting into bed, spend 5 minutes putting away clothes and clearing surfaces.","freq":"daily","days":[]\},\{"id":"mocirvxc9ne3","text":" Spend 15 minutes every Sunday resetting any clutter that crept in during the week.","freq":"weekly","days":[]\}]\},\{"name":"Build the Habit","desc":"Maintain a 100% \\"Ready State\\" bedroom for 12 consecutive weeks (continued).","tactics":[\{"id":"mociqm5xnkgc","text":"Before getting into bed, spend 5 minutes putting away clothes and clearing surfaces.","freq":"daily","days":[]\},\{"id":"mocir8sbgnvp","text":" Spend 15 minutes every Sunday resetting any clutter that crept in during the week.","freq":"weekly","days":[]\}]\},\{"name":"Peak","desc":"Maintain a 100% \\"Ready State\\" bedroom for 12 consecutive weeks (continued).","tactics":[\{"id":"mocir4g7tuua","text":"Before getting into bed, spend 5 minutes putting away clothes and clearing surfaces.","freq":"daily","days":[]\},\{"id":"mocirj7xb531","text":" Spend 15 minutes every Sunday resetting any clutter that crept in during the week.","freq":"weekly","days":[]\}]\}]\}]\}}